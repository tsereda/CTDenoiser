Here is a PyTorch implementation of the CTformer architecture described in the paper, designed to be integrated directly into your existing benchmark pipeline alongside your RED-CNN baseline.

Given your focus on advanced network design and synthesis tasks, this implementation modularizes the Token2Token Dilation (T2TD) blocks, cyclic shifts, and the symmetric inverse operations (IT2TD) so you can easily modify the latent representations or swap the standard Multi-Head Attention for a Performer module if memory during training becomes a bottleneck.
1. CTformer PyTorch Architecture
Python

import torch
import torch.nn as nn
import torch.nn.functional as F
import math

class CyclicShift(nn.Module):
    def __init__(self, shift_size):
        super().__init__()
        self.shift_size = shift_size

    def forward(self, x):
        # x shape: (B, C, H, W)
        return torch.roll(x, shifts=(self.shift_size, self.shift_size), dims=(2, 3))

class TransformerBlock(nn.Module):
    def __init__(self, dim, num_heads=4, mlp_ratio=4.0):
        super().__init__()
        self.norm1 = nn.LayerNorm(dim)
        # Using standard MHA. For strict adherence to the paper's efficiency, 
        # swap this with a Performer attention variant.
        self.attn = nn.MultiheadAttention(embed_dim=dim, num_heads=num_heads, batch_first=True)
        self.norm2 = nn.LayerNorm(dim)
        self.mlp = nn.Sequential(
            nn.Linear(dim, int(dim * mlp_ratio)),
            nn.GELU(),
            nn.Linear(int(dim * mlp_ratio), dim)
        )

    def forward(self, x):
        res = x
        x = self.norm1(x)
        x, _ = self.attn(x, x, x)
        x = res + x
        
        res = x
        x = self.norm2(x)
        x = self.mlp(x)
        return res + x

class T2TDilation(nn.Module):
    def __init__(self, in_dim, out_dim, kernel_size, dilation, shift_size):
        super().__init__()
        self.cyclic_shift = CyclicShift(shift_size)
        self.unfold = nn.Unfold(kernel_size=kernel_size, dilation=dilation, padding=dilation, stride=1)
        self.proj = nn.Linear(in_dim * kernel_size**2, out_dim)

    def forward(self, x, spatial_size):
        B, N, C = x.shape
        H, W = spatial_size
        
        # 1. Reshaping
        x = x.transpose(1, 2).view(B, C, H, W)
        
        # 2. Cyclic Shift
        x = self.cyclic_shift(x)
        
        # 3. Dilated Unfold
        x = self.unfold(x) # (B, C*K*K, L)
        x = x.transpose(1, 2) # (B, L, C*K*K)
        x = self.proj(x)
        
        # New spatial dimension assuming stride=1 and padding maintains dims
        return x, (H, W)

class CTformer(nn.Module):
    def __init__(self, in_channels=1, embed_dim=64):
        super().__init__()
        
        # Tokenization (k=7, s=2, p=3 to maintain dims gracefully or as specified)
        self.tokenization = nn.Conv2d(in_channels, embed_dim, kernel_size=7, stride=2, padding=3)
        
        # Encoder CTformer Modules (TB + T2TD)
        self.enc_tb1 = TransformerBlock(dim=embed_dim)
        self.t2td1 = T2TDilation(embed_dim, embed_dim, kernel_size=3, dilation=2, shift_size=2)
        
        self.enc_tb2 = TransformerBlock(dim=embed_dim)
        self.t2td2 = T2TDilation(embed_dim, embed_dim, kernel_size=3, dilation=1, shift_size=2)
        
        # Intermediate
        self.bottleneck_tb = TransformerBlock(dim=embed_dim)
        
        # Decoder CTformer Modules (IT2TD + TB)
        # Using transposed convolutions or inverse unfold to handle upsampling
        self.it2td1 = T2TDilation(embed_dim, embed_dim, kernel_size=3, dilation=1, shift_size=-2)
        self.dec_tb1 = TransformerBlock(dim=embed_dim)
        
        self.it2td2 = T2TDilation(embed_dim, embed_dim, kernel_size=3, dilation=2, shift_size=-2)
        self.dec_tb2 = TransformerBlock(dim=embed_dim)
        
        # Detokenization
        self.detokenization = nn.ConvTranspose2d(embed_dim, 1, kernel_size=7, stride=2, padding=3, output_padding=1)

    def forward(self, x):
        B, C, H, W = x.shape
        
        # Tokenization
        x = self.tokenization(x) # (B, D, H/2, W/2)
        spatial_shape = (x.shape[2], x.shape[3])
        x = x.flatten(2).transpose(1, 2) # (B, N, D)
        
        # Encoder
        x = self.enc_tb1(x)
        x, spatial_shape = self.t2td1(x, spatial_shape)
        
        x = self.enc_tb2(x)
        x, spatial_shape = self.t2td2(x, spatial_shape)
        
        # Bottleneck
        x = self.bottleneck_tb(x)
        
        # Decoder
        x, spatial_shape = self.it2td1(x, spatial_shape)
        x = self.dec_tb1(x)
        
        x, spatial_shape = self.it2td2(x, spatial_shape)
        x = self.dec_tb2(x)
        
        # Detokenization
        x = x.transpose(1, 2).view(B, -1, spatial_shape[0], spatial_shape[1])
        x = self.detokenization(x)
        
        return x

2. Overlapped Inference Utility

Since transformer denoising architectures inherently process locally structured token sets, stitching raw patches leads to grid/boundary artifacts. The authors addressed this with an overlapped inference pipeline discarding margin η. You can wrap your standard DataLoader logic with this mechanism during the evaluation phase:
Python

def overlapped_inference(model, full_img, patch_size=64, margin=16):
    """
    Evaluates a full CT slice using overlapped inference to prevent boundary artifacts.
    """
    model.eval()
    B, C, H, W = full_img.shape
    out_img = torch.zeros_like(full_img)
    weight_map = torch.zeros_like(full_img)
    
    stride = patch_size - 2 * margin
    
    with torch.no_grad():
        for y in range(0, H - patch_size + 1, stride):
            for x in range(0, W - patch_size + 1, stride):
                # Extract patch
                patch = full_img[:, :, y:y+patch_size, x:x+patch_size]
                
                # Model inference
                denoised_patch = model(patch)
                
                # Discard margin and keep center
                center_crop = denoised_patch[:, :, margin:-margin, margin:-margin]
                
                # Add to output
                out_img[:, :, y+margin:y+patch_size-margin, x+margin:x+patch_size-margin] += center_crop
                weight_map[:, :, y+margin:y+patch_size-margin, x+margin:x+patch_size-margin] += 1
                
    # Average the overlapping regions
    return out_img / torch.clamp(weight_map, min=1.0)